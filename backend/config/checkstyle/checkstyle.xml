<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!--
  월급앱 checkstyle — 목적은 단 하나: CLAUDE.md 규칙 3의 기계 강제.
  "날짜 연산은 전부 Asia/Seoul. LocalDate.now() 직접 호출 금지, Clock 주입."
  인자 없는 now()만 잡는다 — now(clock)는 통과.
-->
<module name="Checker">
  <property name="charset" value="UTF-8"/>
  <module name="TreeWalker">
    <module name="RegexpSinglelineJava">
      <property name="format"
                value="\b(LocalDate|LocalDateTime|LocalTime|ZonedDateTime|OffsetDateTime|Instant|YearMonth)\.now\(\s*\)"/>
      <property name="message"
                value="now() 직접 호출 금지 — 주입된 Clock을 사용할 것: now(clock) (CLAUDE.md 규칙 3, Asia/Seoul 고정)"/>
      <property name="ignoreComments" value="true"/>
    </module>
  </module>
</module>
